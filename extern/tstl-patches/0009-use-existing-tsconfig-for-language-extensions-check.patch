From dffe00fdbe3857dcab83552a5e3b6101da841a2c Mon Sep 17 00:00:00 2001
From: Cold Fry <coldfry.business@gmail.com>
Date: Fri, 3 Apr 2026 02:00:15 +0100
Subject: [PATCH 9/9] use existing tsconfig for language-extensions check

---
 package.json | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/package.json b/package.json
index a59b521..a8513b1 100644
--- a/package.json
+++ b/package.json
@@ -31,7 +31,7 @@
         "lint:prettier": "prettier --check . || (echo 'Run `npm run fix:prettier` to fix it.' && exit 1)",
         "lint:eslint": "eslint .",
         "fix:prettier": "prettier --write .",
-        "check:language-extensions": "tsc --strict --ignoreConfig language-extensions/index.d.ts",
+        "check:language-extensions": "tsc -p language-extensions/tsconfig.json",
         "preversion": "npm run build && npm test",
         "postversion": "git push && git push --tags"
     },
-- 
2.50.1 (Apple Git-155)

